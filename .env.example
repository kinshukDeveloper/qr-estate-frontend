# ─────────────────────────────────────────────
#  QR ESTATE — FRONTEND ENVIRONMENT VARIABLES
#  Copy to .env.local and fill in values
# ─────────────────────────────────────────────

# Backend API URL (used by Next.js rewrites + server components)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# App info
NEXT_PUBLIC_APP_NAME=QR Estate
NEXT_PUBLIC_APP_URL=http://localhost:3000

# QR short URL base (for display purposes)
NEXT_PUBLIC_SHORT_URL_BASE=http://localhost:5000/q

# Google Maps (for property page map embed)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cloudinary (for direct frontend uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=qr_estate_unsigned
